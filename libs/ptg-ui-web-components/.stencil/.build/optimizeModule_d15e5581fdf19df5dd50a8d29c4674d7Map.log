{"version":3,"names":["ptgCardCss","PtgCardStyle0","PtgCard","constructor","hostRef","this","src","cardTitle","cardContent","isCardAction","cardButtonText","clickbutn","event","handleClick","emit","render","h","key","class","length","cardContentLength","slice","appearance","text","onClick","cardId"],"sources":["../../../libs/ptg-ui-web-components/src/components/ptg-card/ptg-card.scss?tag=ptg-card&encapsulation=shadow","../../../libs/ptg-ui-web-components/src/components/ptg-card/ptg-card.tsx"],"sourcesContent":[":host {\r\n  display: block;\r\n}\r\n.ptg-card-wrapper {\r\n  border: 1px solid #dee2e6;\r\n  border-radius: 8px;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  .ptg-card-img-wrapper {\r\n    height: 200px;\r\n    width: 100%;\r\n    position: relative;\r\n    border-radius: 8px 8px 0 0;\r\n    object-fit: cover;\r\n    overflow: hidden;\r\n    img {\r\n      position: absolute;\r\n      inset: 0;\r\n      width: 100%;\r\n      border-radius: 8px 8px 0 0;\r\n    }\r\n  }\r\n  .ptg-card-content-wrapper {\r\n    width:100%;\r\n    padding:15px;\r\n    .ptg-card-heading{\r\n      padding: 0;\r\n      margin: 0;\r\n      margin-bottom: 10px;\r\n      text-transform:  capitalize;\r\n      font-size: 18px;\r\n    }\r\n    .ptg-card-content{ font-size: 14px;}\r\n  }\r\n  .ptg-card-footer{ padding: 10px; width: 100%;}\r\n}","import { Component, h, Prop, Event, EventEmitter } from '@stencil/core';\r\n\r\n@Component({\r\n  tag: 'ptg-card',\r\n  styleUrl: 'ptg-card.scss',\r\n  shadow: true,\r\n})\r\nexport class PtgCard {\r\n  @Prop() src: string = '';\r\n  @Prop() cardContentLength?: number;\r\n  @Prop() cardTitle: string = '';\r\n  @Prop() cardContent: string = '';\r\n  @Prop() cardId: number;\r\n  @Prop() isCardAction: boolean = false;\r\n  @Prop() cardButtonText: string = 'select';\r\n  @Event() handleClick?: EventEmitter;\r\n\r\n  clickbutn(event) {\r\n    this.handleClick.emit(event);\r\n  }\r\n\r\n  render() {\r\n    return (\r\n      <div class=\"ptg-card-wrapper\">\r\n        {this.src !== '' && (\r\n          <div class=\"ptg-card-img-wrapper\">\r\n            <img src={this.src} />\r\n          </div>\r\n        )}\r\n        {(this.cardTitle != '' || this.cardContent !== '') && (\r\n          <div class=\"ptg-card-content-wrapper\">\r\n            {this.cardTitle && (\r\n              <h2 class=\"ptg-card-heading\">{this.cardTitle}</h2>\r\n            )}\r\n            {this.cardContent && (\r\n              <div class=\"ptg-card-content\">\r\n                {this.cardContent.length > this.cardContentLength\r\n                  ? this.cardContent.slice(0, this.cardContentLength) + '...'\r\n                  : this.cardContent}\r\n              </div>\r\n            )}\r\n          </div>\r\n        )}\r\n        {this.isCardAction && (\r\n          <div class=\"ptg-card-footer\">\r\n            <ptg-button\r\n              appearance=\"primary\"\r\n              text={this.cardButtonText}\r\n              onClick={() => this.clickbutn(this.cardId)}\r\n            ></ptg-button>\r\n          </div>\r\n        )}\r\n      </div>\r\n    );\r\n  }\r\n}\r\n"],"mappings":"kDAAA,MAAMA,EAAa,isBACnB,MAAAC,EAAeD,E,MCMFE,EAAO,MALpB,WAAAC,CAAAC,G,mDAMUC,KAAAC,IAAc,GAEdD,KAAAE,UAAoB,GACpBF,KAAAG,YAAsB,GAEtBH,KAAAI,aAAwB,MACxBJ,KAAAK,eAAyB,Q,CAGjC,SAAAC,CAAUC,GACRP,KAAKQ,YAAYC,KAAKF,E,CAGxB,MAAAG,GACE,OACEC,EAAA,OAAAC,IAAA,2CAAKC,MAAM,oBACRb,KAAKC,MAAQ,IACZU,EAAA,OAAAC,IAAA,2CAAKC,MAAM,wBACTF,EAAA,OAAAC,IAAA,2CAAKX,IAAKD,KAAKC,QAGjBD,KAAKE,WAAa,IAAMF,KAAKG,cAAgB,KAC7CQ,EAAA,OAAAC,IAAA,2CAAKC,MAAM,4BACRb,KAAKE,WACJS,EAAA,MAAAC,IAAA,2CAAIC,MAAM,oBAAoBb,KAAKE,WAEpCF,KAAKG,aACJQ,EAAA,OAAAC,IAAA,2CAAKC,MAAM,oBACRb,KAAKG,YAAYW,OAASd,KAAKe,kBAC5Bf,KAAKG,YAAYa,MAAM,EAAGhB,KAAKe,mBAAqB,MACpDf,KAAKG,cAKhBH,KAAKI,cACJO,EAAA,OAAAC,IAAA,2CAAKC,MAAM,mBACTF,EAAA,cAAAC,IAAA,2CACEK,WAAW,UACXC,KAAMlB,KAAKK,eACXc,QAAS,IAAMnB,KAAKM,UAAUN,KAAKoB,W","ignoreList":[]}