{"version":3,"names":["ptgAccordionCss","PtgAccordionStyle0","PtgAccordion","constructor","hostRef","this","toggle","defaultOpened","componentWillLoad","toggleComponent","render","h","key","class","style","backgroundColor","bgColor","onClick","label","description","name"],"sources":["../../../libs/ptg-ui-web-components/src/components/ptg-accordion/ptg-accordion.scss?tag=ptg-accordion&encapsulation=shadow","../../../libs/ptg-ui-web-components/src/components/ptg-accordion/ptg-accordion.tsx"],"sourcesContent":[":host {\r\n  display: block;\r\n}\r\n\r\n.accordion {\r\n  position: relative;\r\n    cursor: pointer;\r\n    padding: 18px;\r\n    text-align: left;\r\n    font-family: inherit;\r\n    font-size: inherit;\r\n    line-height: inherit;\r\n    border: 0.5px solid var(--mono-15);\r\n    width: 100%;\r\n    overflow-anchor: none;\r\n\r\n    &.active {\r\n      box-shadow: inset 0 -1px 0 var(--mono-20);\r\n    }\r\n   }\r\n  \r\n  .accordion .body {\r\n    color: var(--mono-50);\r\n    font-size: 14px;\r\n    height: auto;\r\n    line-height: 21px;\r\n    max-height: 320px;\r\n    overflow-y: auto;\r\n    padding: 16px;\r\n  }\r\n  \r\n  .content-box-inner {\r\n    border: 0.5px solid var(--mono-15);\r\n    padding: 18px;\r\n    background-color: var(--white);\r\n  }\r\n  \r\n  .content-box {\r\n    overflow: hidden;\r\n    transition: max-height 1s;\r\n    max-height: 0;\r\n  \r\n    &.open {\r\n      box-sizing: border-box;\r\n      max-height: 500px;\r\n    }\r\n  }\r\n  \r\n  .arrow {\r\n    position: absolute;\r\n    top: 60%;\r\n    right: 30px;\r\n    transform: translateY(-50%);\r\n    width: 10px;\r\n    height: 10px;\r\n  }\r\n  \r\n  .arrow::before,\r\n  .arrow::after {\r\n    position: relative;\r\n    content: '';\r\n    display: block;\r\n    width: 100%;\r\n    height: 2px;\r\n    background: #000;\r\n  }\r\n  \r\n  \r\n  .arrow::before {\r\n    transform: rotate(45deg);\r\n  }\r\n  \r\n  .arrow::after {\r\n    left: 7px;\r\n    bottom: 2px;\r\n    transform: rotate(-45deg);\r\n  }\r\n  \r\n  .arrow.down {\r\n    transform: translateY(-50%) rotate(180deg);\r\n    right: 25px;\r\n    top: 45%;\r\n  }","import { Component, h, Prop, State } from '@stencil/core';\r\n\r\n@Component({\r\n  tag: 'ptg-accordion',\r\n  styleUrl: 'ptg-accordion.scss',\r\n  shadow: true,\r\n})\r\nexport class PtgAccordion {\r\n  @State() toggle: boolean = false;\r\n  @Prop() label: string;\r\n  @Prop() description: string;\r\n  @Prop() bgColor?: string;\r\n  @Prop() defaultOpened: boolean = false;\r\n\r\n  componentWillLoad() {\r\n    this.toggle = this.defaultOpened;\r\n  }\r\n\r\n  toggleComponent() {\r\n    this.toggle = !this.toggle;\r\n  }\r\n\r\n  render() {\r\n    return (\r\n      <div>\r\n        <button\r\n          class={`accordion ${this.toggle ? 'active' : ''}`}\r\n          style={{\r\n            backgroundColor: this.bgColor,\r\n          }}\r\n          onClick={() => this.toggleComponent()}>\r\n          {this.label}\r\n          <span class={this.toggle? 'arrow down': 'arrow'}></span>\r\n        </button>\r\n        <div\r\n          class={`content-box ${this.toggle ? 'open' : 'close'}`}>\r\n          <div class=\"content-box-inner\">\r\n            {this.description ? (\r\n              <p>{this.description}</p>\r\n            ) : (\r\n              <div class=\"body\">\r\n                <slot name=\"body-block\" />\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n}\r\n"],"mappings":"2CAAA,MAAMA,EAAkB,0+BACxB,MAAAC,EAAeD,E,MCMFE,EAAY,MALzB,WAAAC,CAAAC,G,UAMWC,KAAAC,OAAkB,MAInBD,KAAAE,cAAyB,K,CAEjC,iBAAAC,GACEH,KAAKC,OAASD,KAAKE,a,CAGrB,eAAAE,GACEJ,KAAKC,QAAUD,KAAKC,M,CAGtB,MAAAI,GACE,OACEC,EAAA,OAAAC,IAAA,4CACED,EAAA,UAAAC,IAAA,2CACEC,MAAO,aAAaR,KAAKC,OAAS,SAAW,KAC7CQ,MAAO,CACLC,gBAAiBV,KAAKW,SAExBC,QAAS,IAAMZ,KAAKI,mBACnBJ,KAAKa,MACNP,EAAA,QAAAC,IAAA,2CAAMC,MAAOR,KAAKC,OAAQ,aAAc,WAE1CK,EAAA,OAAAC,IAAA,2CACEC,MAAO,eAAeR,KAAKC,OAAS,OAAS,WAC7CK,EAAA,OAAA