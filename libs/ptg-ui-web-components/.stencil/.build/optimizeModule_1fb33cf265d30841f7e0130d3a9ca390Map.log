 color: black;\r\n  font-size: 14px;\r\n  height: auto;\r\n  line-height: 21px;\r\n  max-height: 320px;\r\n  overflow-y: auto;\r\n  padding: 16px;\r\n}\r\n\r\n\r\n/* modal footer */\r\n.modal-wrapper .modal .footer{\r\n  align-items: center;\r\n  border-top: 1px solid var(--mono-05);\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  padding: 16px;\r\n}\r\n\r\n.modal-wrapper .modal .footer my-buttons{\r\n  margin: 0 6px;\r\n}\r\n.modal-wrapper .modal .footer ptg-button + ptg-button{\r\n  margin-left: 8px;\r\n}\r\n\r\n.isOpen{\r\n  opacity: 1;\r\n  transition: visibility 0s linear 0.25s,opacity 0.25s 0s,tranform 0.25s;\r\n  visibility: visible;\r\n  z-index: 99999;\r\n\r\n}\r\n.close{\r\n  font-size: 33px;\r\n}\r\n\r\n\r\n// .isOpen .modal{\r\n//   transform: none !important;\r\n// }\r\n\r\n\r\n\r\n","import { Component, h, Prop, Event, EventEmitter } from '@stencil/core';\r\n\r\n@Component({\r\n  tag: 'ptg-modal',\r\n  styleUrl: 'ptg-modal.scss',\r\n  shadow: true,\r\n})\r\nexport class PtgModal {\r\n  // Props\r\n  @Prop() confirmButtonName: string = 'Confirm';\r\n  @Prop() isOpen: boolean = false;\r\n  @Prop() modalHeaderName: string = 'Modal Header';\r\n  @Prop() modalSize: string = 'md';\r\n  @Prop() showHeader: boolean = true;\r\n  @Prop() showFooter: boolean = true;\r\n  @Prop() closeOutsideClick: boolean = false;\r\n  @Prop() primaryBtn: string = 'primary';\r\n  @Prop() cancelBtn: string = 'secondary';\r\n  @Prop() btnName: string = '';\r\n  // Event emitter\r\n  @Event() modalClose: EventEmitter<boolean>;\r\n  @Event() confirmClose: EventEmitter<boolean>;\r\n\r\n  private closeModule = () => {\r\n    this.isOpen = false;\r\n    this.modalClose.emit(true);\r\n  };\r\n  private openModal = () => {\r\n    this.isOpen = true;\r\n    this.modalClose.emit(true);\r\n  };\r\n  // private confirmEvent = () => {\r\n  //   this.confirmClose.emit(true);\r\n  // };\r\n\r\n  render() {\r\n    return (\r\n      <div>\r\n        <div>\r\n          <ptg-button\r\n            text={this.btnName}\r\n            data-testid=\"openButton\"\r\n            appearance=\"modal\"\r\n            onClick={this.openModal}\r\n          ></ptg-button>\r\n        </div>\r\n        {this.isOpen && (\r\n          <div\r\n            class={this.isOpen ? 'modal-wrapper isOpen' : 'modal-wrapper'}\r\n            data-backdrop=\"static\"\r\n          >\r\n            <div\r\n              class={`modal-body modal ${\r\n                this.modalSize == 'lg'\r\n                  ? 'lg'\r\n                  : this.modalSize == 'sm'\r\n                  ? 'sm'\r\n                  : 'md'\r\n              }`}\r\n            >\r\n              {this.showHeader && (\r\n                <div class=\"header\">\r\n                  <h4>{this.modalHeaderName}</h4>\r\n                  <div\r\n                    class=\"close\"\r\n                    data-testid=\"closeButton\"\r\n                    onClick={this.closeModule}\r\n                  >\r\n                    ×\r\n                  </div>\r\n                </div>\r\n              )}\r\n              <div class=\"body\">\r\n                <slot name=\"body-block\" />\r\n              </div>\r\n              {this.showFooter && (\r\n                <div class=\"footer\">\r\n                  <ptg-button\r\n                    text={this.confirmButtonName}\r\n                    appearance={this.primaryBtn}\r\n                    onClick={this.closeModule}\r\n                  ></ptg-button>\r\n                </div>\r\n              )}\r\n            </div>\r\n          </div>\r\n        )}\r\n        {this.isOpen && (\r\n          <div\r\n            class=\"modal-overlay1\"\r\n            onClick={this.closeOutsideClick && this.closeModule}\r\n          ></div>\r\n        )}\r\n      </div>\r\n    );\r\n  }\r\n}\r\n"],"mappings":"kDAAA,MAAMA,EAAc,q8C,MCOPC,EAAQ,MALrB,WAAAC,CAAAC,G,wFAOUC,KAAiBC,kBAAW,UAC5BD,KAAME,OAAY,MAClBF,KAAeG,gBAAW,eAC1BH,KAASI,UAAW,KACpBJ,KAAUK,WAAY,KACtBL,KAAUM,WAAY,KACtBN