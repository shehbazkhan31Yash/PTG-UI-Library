 label:hover {\r\n  opacity: 1;\r\n}\r\n\r\n.carousel-controls .prev-slide {\r\n  left: 0;\r\n  text-align: left;\r\n  width: 20%;\r\n}\r\n\r\n.carousel-controls .next-slide {\r\n  right: 0;\r\n  text-align: right;\r\n  width: 20%;\r\n}\r\n\r\n.carousel-dots {\r\n  bottom: 20px;\r\n  cursor: pointer;\r\n  left: 0;\r\n  position: absolute;\r\n  right: 0;\r\n  text-align: center;\r\n  z-index: 999;\r\n}\r\n\r\n.carousel-dots .carousel-dot {\r\n  background-color: #fff;\r\n  border-radius: 50%;\r\n  cursor: pointer;\r\n  display: inline-block;\r\n  height: 10px;\r\n  margin: 10px;\r\n  opacity: 0.5;\r\n  width: 10px;\r\n}\r\n\r\ninput:checked + .slide-container .slide-image {\r\n  opacity: 1;\r\n  transform: scale(1);\r\n  transition: opacity 1s ease-in-out;\r\n}\r\n\r\ninput:checked + .slide-container .carousel-controls label {\r\n   display: block;\r\n}\r\n\r\ninput#img-1:checked ~ .carousel-dots label#img-dot-1,\r\ninput#img-2:checked ~ .carousel-dots label#img-dot-2,\r\ninput#img-3:checked ~ .carousel-dots label#img-dot-3,\r\ninput#img-4:checked ~ .carousel-dots label#img-dot-4,\r\ninput#img-5:checked ~ .carousel-dots label#img-dot-5,\r\ninput#img-6:checked ~ .carousel-dots label#img-dot-6 {\r\nopacity: 1;\r\n}\r\n\r\ninput:checked + .slide-container .nav label { display: block; }\r\n","import { Component, h, Prop } from '@stencil/core';\r\n\r\n@Component({\r\n  tag: 'ptg-ui-carousel',\r\n  styleUrl: 'ptg-carousel.scss',\r\n  shadow: true,\r\n})\r\nexport class PtgCarousel {\r\n  @Prop() images: Array<string> = [];\r\n\r\n  @Prop() imgWidth: string = '200';\r\n  @Prop() imgHeight: string = '200';\r\n  @Prop() showIndicators: boolean = true;\r\n\r\n  render() {\r\n    return (\r\n      <div class=\"parent-container\">\r\n        <div class=\"carousel\">\r\n          <ul\r\n            class=\"slides\"\r\n            style={{\r\n              minHeight: `${this.imgHeight}px`,\r\n              minWidth: `${this.imgWidth}px`,\r\n            }}\r\n          >\r\n            {this.images.length\r\n              ? this.images.map((imgPath, index) => {\r\n                  return (\r\n                    <div>\r\n                      <input\r\n                        type=\"radio\"\r\n                        name=\"radio-buttons\"\r\n                        id={`img-${index}`}\r\n                        checked\r\n                      />\r\n                      <li class=\"slide-container\">\r\n                        <div class=\"slide-image\">\r\n                          <img src={imgPath} alt=\"Image\" />\r\n                        </div>\r\n                        <div\r\n                          class=\"carousel-controls\"\r\n                          style={{ lineHeight: `${this.imgHeight}px` }}\r\n                        >\r\n                          <label\r\n                            htmlFor={`img-${\r\n                              index == 0 ? this.images.length - 1 : index - 1\r\n                            }`}\r\n                            class=\"prev-slide\"\r\n                          >\r\n                            <span>&lsaquo;</span>\r\n                          </label>\r\n                          <label\r\n                            htmlFor={`img-${\r\n                              index == this.images.length - 1 ? 0 : index + 1\r\n                            }`}\r\n                            class=\"next-slide\"\r\n                          >\r\n                            <span>&rsaquo;</span>\r\n                          </label>\r\n                        </div>\r\n                      </li>\r\n                    </div>\r\n                  );\r\n                })\r\n              : null}\r\n            {this.showIndicators && (\r\n              <div class=\"carousel-dots\">\r\n                {this.images.map((imgPath, index) => (\r\n                  <label\r\n                    htmlFor={`img-${index}`}\r\n                    class=\"carousel-dot\"\r\n                    id={`img-dot-${index}`}\r\n                    key={imgPath}\r\n                  ></label>\r\n                ))}\r\n              </div>\r\n            )}\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n}\r\n"],"mappings":"2CAAA,MAAMA,EAAiB,k3DACvB,MAAAC,EAAeD,E,MCMFE,EAAW,MALxB,WAAAC,CAAAC,G,UAMUC,KAAAC,OAAwB,GAExBD,KAAAE,SAAmB,MACnBF,KAAAG,UAAoB,MACpBH,KAAAI,eAA0B,I,CAElC,MAAAC,GACE,OACEC,EAAA,OAAAC,IAAA,2CAAKC,MAAM,oBACTF,EAAA,OAAAC,IAAA,2CAAKC,MAAM,YACTF,EAAA,MAAAC,IAAA,2CACEC,MAAM,SACNC,MAAO,CACLC,UAAW,GAAGV,KAAKG,cACnBQ,SAAU,GAAGX,KAAKE,eAGnBF,KAAKC,OAAOW,OACTZ,KAAKC,OAAOY,KAAI,CAACC,EAASC,IAEtBT,EAAA,WACEA,EAAA,SACEU,KAAK,QACLC,KAAK,gBACLC,GAAI,OAAOH,IACXI,QAAO,OAETb,EAAA,MAAIE,MAAM,mBACRF,EAAA,OAAKE,MAAM,eACTF,EAAA,OAAKc,IAAKN,EAASO,IAAI,WAEzBf,EAAA,OACEE,MAAM,oBACNC,MAAO,CAAEa,WAAY,GAAGtB,KAAKG,gBAE7BG,EAAA,SACEiB,QAAS,OACPR,GAAS,EAAIf,KAAKC,OAAOW,OAAS,EAAIG,EAAQ,IAEhDP,MAAM,cAENF,EAAA,kBAEFA,EAAA,SACEiB,QAAS,OACPR,GAASf,KAAKC,OAAOW,OAAS,EAAI,EAAIG,EAAQ,IAEhDP,MAAM,cAENF,EAAA,uBAOZ,KACHN,KAAKI,gBACJE,EAAA,OAAAC,IAAA,2CAAKC,MAAM,iBACRR,KAAKC,OAAOY,KAAI,CAACC,EAASC,IACzBT,EAAA,SACEiB,QAAS,OAAOR,IAChBP,MAAM,eACNU,GAAI,WAAWH,IACfR,IAAKO,S","ignoreList":[]}