th of inout value\r\n   */\r\n  @Prop() width = '100%';\r\n\r\n  changeHandler(event: any) {\r\n    this.value = (event.target as HTMLInputElement).value;\r\n    this.valueChanged.emit(this.value);\r\n  }\r\n\r\n  render() {\r\n    return (\r\n      <div>\r\n        <label htmlFor={this.inputId}>{this.label}</label>\r\n        <input\r\n          type={this.type}\r\n          id={this.inputId}\r\n          name={this.name}\r\n          placeholder={this.placeholder}\r\n          onInput={this.changeHandler.bind(this)}\r\n        ></input>\r\n      </div>\r\n    );\r\n  }\r\n}\r\n",":host {\r\n  display: block;\r\n  border: 1px solid #eee;\r\n  padding: 4px;\r\n\r\n  > div {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n  }\r\n\r\n  .pages {\r\n    margin-right: auto;\r\n\r\n    &,\r\n    a {\r\n      border-radius: 2px;\r\n    }\r\n  }\r\n\r\n  .counts {\r\n    margin-right: 18px;\r\n  }\r\n\r\n  .size {\r\n    margin-right: 4px;\r\n  }\r\n\r\n  a {\r\n    cursor: pointer;\r\n    text-decoration: none;\r\n    display: inline-block;\r\n    padding: 2px 8px;\r\n    border: 1px solid #fafafa;\r\n    margin-right: 4px;\r\n    transition: all 0.1s linear;\r\n    user-select: none;\r\n\r\n    &:hover {\r\n      border-color: #aaa;\r\n    }\r\n\r\n    &.active {\r\n      color: #00f;\r\n      border-color: #00f;\r\n    }\r\n\r\n    &.disabled {\r\n      cursor: default;\r\n      color: #bbb;\r\n\r\n      &:hover {\r\n        border-color: #fafafa;\r\n      }\r\n    }\r\n  }\r\n}\r\n","import { Component, Event, EventEmitter, Prop, h } from '@stencil/core';\r\n\r\n@Component({\r\n  tag: 'ptg-pagination',\r\n  styleUrl: 'ptg-pagination.scss',\r\n  scoped: true,\r\n})\r\nexport class PtgPagination {\r\n  @Prop() page: number = 0;\r\n  @Prop() pageSize: number = 10;\r\n  @Prop() pageSizeOptions: number[] = [];\r\n  @Prop() itemCount: number;\r\n\r\n  @Event() pageChanged: EventEmitter;\r\n  @Event() sizeChanged: EventEmitter;\r\n\r\n  private pageCount: number = 0;\r\n\r\n  private handlePrevious(event) {\r\n    if (this.page !== 0) {\r\n      this.handleSelect(event, this.page - 1);\r\n    }\r\n  }\r\n\r\n  private handleNext(event) {\r\n    if (this.page !== this.pageCount - 1) {\r\n      this.handleSelect(event, this.page + 1);\r\n    }\r\n  }\r\n\r\n  private handleSelect(event: UIEvent, index: number) {\r\n    event.preventDefault();\r\n    this.pageChanged.emit(index);\r\n  }\r\n\r\n  private handlePageSizeChange(event) {\r\n    this.sizeChanged.emit(Number(event.currentTarget.value));\r\n  }\r\n\r\n  render() {\r\n    if (this.itemCount) {\r\n      let pages = [];\r\n      const start = this.page * this.pageSize + 1;\r\n      const end = this.page * this.pageSize + this.pageSize;\r\n\r\n      for (let i = 0; i < this.itemCount / this.pageSize; i++) {\r\n        pages.push(i);\r\n      }\r\n\r\n      this.pageCount = pages.length;\r\n\r\n      return (\r\n        <div>\r\n          <span class=\"pages\">\r\n            <span>\r\n              <a\r\n                class={this.page === 0 ? 'disabled' : ''}\r\n                onClick={(event) => this.handlePrevious(event)}\r\n              >\r\n                Previous\r\n              </a>\r\n            </span>\r\n            <span>\r\n              {pages.map((index) => (\r\n                <a\r\n                  class={this.page === index ? 'active' : ''}\r\n                  onClick={(event) => this.handleSelect(event, index)}\r\n                >\r\n                  {index + 1}\r\n                </a>\r\n              ))}\r\n            </span>\r\n            <span>\r\n              <a\r\n                class={this.page === pages.length - 1 ? 'disabled' : ''}\r\n                onClick={(event) => this.handleNext(event)}\r\n              >\r\n                Next\r\n              </a>\r\n            </span>\r\n          </span>\r\n          <span class=\"counts\">\r\n            {start} -{' '}\r\n            {this.page === pages[pages.length - 1] ? this.itemCount : end} of{' '}\r\n            {this.itemCount}\r\n          </span>\r\n          {this.pageSizeOptions.length ? (\r\n            <span class=\"size\">\r\n              <select onChange={(event) => this.handlePageSizeChange(event)}>\r\n                {this.pageSizeOptions.map((n) => (\r\n                  <option>{n}</option>\r\n                ))}\r\n              </select>{' '}\r\n              per page\r\n            </span>\r\n          ) : (\r\n            <span></span>\r\n          )}\r\n        </div>\r\n      );\r\n    }\r\n  }\r\n}\r\n"],"mappings":"kDAAA,MAAMA,EAAc,6HACpB,MAAAC,EAAeD,E,MCMFE,EAAQ,MALrB,WAAAC,CAAAC,G,qDAwBUC,KAAAC,YAAc,GAUdD,KAAAE,MAAQ,GAURF,KAAAG,MAAQ,M,CAEhB,aAAAC,CAAcC,GACZL,KAAKE,MAASG,EAAMC,OAA4BJ,MAChDF,KAAKO,aAAaC,KAAKR,KAAKE,M,CAG9B,MAAAO,GACE,OACEC,EAAA,OAAAC,IAAA,4CACED,EAAA,SAAAC,IAAA,2CAAOC,QAASZ,KAAKa,SAAUb,KAAKc,OACpCJ,EAAA,SAAAC,IAAA,2CACEI,KAAMf,KAAKe,KACXC,GAAIhB,KAAKa,QACTI,KAAMjB,KAAKiB,KACXhB,YAAaD,KAAKC,YAClBiB,QAASlB,KAAKI,cAAce,KAAKnB,Q,aC9D3C,MAAMoB,EAAmB,i+BACzB,MAAAC,EAAeD,E,MCMFE,EAAa,MAL1B,WAAAxB,CAAAC,G,4FAMUC,KAAAuB,KAAe,EACfvB,KAAAwB,SAAmB,GACnBxB,KAAAyB,gBAA4B,GAM5BzB,KAAA0B,UAAoB,C,CAEpB,cAAAC,CAAetB,GACrB,GAAIL,KAAKuB,OAAS,EAAG,CACnBvB,KAAK4B,aAAavB,EAAOL,KAAKuB,KAAO,E,EAIjC,UAAAM,CAAWxB,GACjB,GAAIL,KAAKuB,OAASvB,KAAK0B,UAAY,EAAG,CACpC1B,KAAK4B,aAAavB,EAAOL,KAAKuB,KAAO,E,EAIjC,YAAAK,CAAavB,EAAgByB,GACnCzB,EAAM0B,iBACN/B,KAAKgC,YAAYxB,KAAKsB,E,CAGhB,oBAAAG,CAAqB5B,GAC3BL,KAAKkC,YAAY1B,KAAK2B,OAAO9B,EAAM+B,cAAclC,O,CAGnD,MAAAO,GACE,GAAIT,KAAKqC,UAAW,CAClB,IAAIC,EAAQ,GACZ,MAAMC,EAAQvC,KAAKuB,KAAOvB,KAAKwB,SAAW,EAC1C,MAAMgB,EAAMxC,KAAKuB,KAAOvB,KAAKwB,SAAWxB,KAAKwB,SAE7C,IAAK,IAAIiB,EAAI,EAAGA,EAAIzC,KAAKqC,UAAYrC,KAAKwB,SAAUiB,IAAK,CACvDH,EAAMI,KAAKD,E,CAGbzC,KAAK0B,UAAYY,EAAMK,OAEvB,OACEjC,EAAA,OAAAC,IAAA,4CACED,EAAA,QAAAC,IAAA,2CAAMiC,MAAM,SACVlC,EAAA,QAAAC,IAAA,4CACED,EAAA,KAAAC,IAAA,2CACEiC,MAAO5C,KAAKuB,OAAS,EAAI,WAAa,GACtCsB,QAAUxC,GAAUL,KAAK2B,eAAetB,IAAM,aAKlDK,EAAA,Q