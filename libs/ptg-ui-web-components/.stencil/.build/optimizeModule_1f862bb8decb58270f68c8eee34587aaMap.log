{"version":3,"names":["ptgTableCss","PtgTable","constructor","hostRef","this","page","itemCount","pageSize","pageSizeOptions","sortable","searchable","isSort","searchvalue","tablesort","value","tablelist","tabledata","sort","a","b","handleSelected","event","detail","start","end","slice","handleSizeChanged","tableOrder","val","activeSortColumn","toLowerCase","watchSearch","keyword","toString","results","filter","user","Object","keys","some","key","includes","updateTableData","getinputValue","componentDidLoad","length","render","h","class","placeholder","themeColor","tableStrip","tableHover","customClass","_a","tablecolumn","map","column","sorting","accending","header","onClick","_b","colSpan","_c","tableItem"],"sources":["../../../libs/ptg-ui-web-components/src/components/ptg-table/ptg-table.scss?tag=ptg-table&encapsulation=shadow","../../../libs/ptg-ui-web-components/src/components/ptg-table/ptg-table.tsx"],"sourcesContent":[".ptg-table-wrapper {\r\n  .ptg-table {\r\n    width: 100%;\r\n    table-layout: fixed;\r\n    border-spacing: 0;\r\n    border-collapse: collapse;\r\n    tr {\r\n      th,\r\n      td {\r\n        padding: 8px 18px;\r\n        border-top: 1px solid rgba(0, 0, 0, 0.125);\r\n        text-align: left;\r\n      }\r\n    }\r\n    thead {\r\n      tr {\r\n        background: #f8f9fa;\r\n        th {\r\n          font-weight: 600;\r\n          padding: 12px 18px;\r\n          text-align: left;\r\n        }\r\n      }\r\n    }\r\n  }\r\n  // table theming\r\n  .ptg-table {\r\n    &-strip {\r\n      &.ptg-table-primary {\r\n        tr {\r\n          &:nth-child(even) {\r\n            background: rgba(#007bff, 0.4);\r\n          }\r\n        }\r\n      }\r\n      &.ptg-table-secondary {\r\n        tr {\r\n          &:nth-child(even) {\r\n            background: rgba(#6c757d, 0.4);\r\n          }\r\n        }\r\n      }\r\n      &.ptg-table-warning {\r\n        tr {\r\n          &:nth-child(even) {\r\n            background: rgba(#ffc107, 0.4);\r\n          }\r\n        }\r\n      }\r\n      &.ptg-table-danger {\r\n        tr {\r\n          &:nth-child(even) {\r\n            background: rgba(#dc3545, 0.4);\r\n          }\r\n        }\r\n      }\r\n      &.ptg-table-success {\r\n        tr {\r\n          &:nth-child(even) {\r\n            background: rgba(#28a745, 0.4);\r\n          }\r\n        }\r\n      }\r\n      &.ptg-table-danger {\r\n        tr {\r\n          &:nth-child(even) {\r\n            background: rgba(#dc3545, 0.4);\r\n          }\r\n        }\r\n      }\r\n      tr {\r\n        &:nth-child(even) {\r\n          background: lighten(#f8f9fa, 0.5);\r\n        }\r\n      }\r\n    }\r\n    &-primary {\r\n      thead {\r\n        tr {\r\n          background: rgba(#007bff, 0.4);\r\n        }\r\n      }\r\n      tbody {\r\n        tr {\r\n          background: rgba(#007bff, 0.3);\r\n        }\r\n      }\r\n    }\r\n    &-secondary {\r\n      thead {\r\n        tr {\r\n          background: rgba(#6c757d, 0.4);\r\n        }\r\n      }\r\n      tbody {\r\n        tr {\r\n          background: rgba(#6c757d, 0.3);\r\n        }\r\n      }\r\n    }\r\n    &-warning {\r\n      thead {\r\n        tr {\r\n          background: rgba(#ffc107, 0.4);\r\n        }\r\n      }\r\n      tbody {\r\n        tr {\r\n          background: rgba(#ffc107, 0.3);\r\n        }\r\n      }\r\n    }\r\n    &-danger {\r\n      thead {\r\n        tr {\r\n          background: rgba(#dc3545, 0.4);\r\n        }\r\n      }\r\n      tbody {\r\n        tr {\r\n          background: rgba(#dc3545, 0.3);\r\n        }\r\n      }\r\n    }\r\n    &-success {\r\n      thead {\r\n        tr {\r\n          background: rgba(#28a745, 0.4);\r\n        }\r\n      }\r\n      tbody {\r\n        tr {\r\n          background: rgba(#28a745, 0.3);\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.table-search {\r\n  margin-bottom: 20px;\r\n}\r\n.no-record-found {\r\n  text-align: center !important;\r\n}\r\n\r\n.sorting {\r\n  position: relative;\r\n\r\n  &:before,\r\n  &:after {\r\n    border: 4px solid transparent;\r\n    content: '';\r\n    display: block;\r\n    height: 0;\r\n    right: 5px;\r\n    top: 50%;\r\n    position: absolute;\r\n    width: 0;\r\n  }\r\n  &:before {\r\n    border-bottom-color: #666;\r\n    margin-top: -9px;\r\n    opacity: 1;\r\n  }\r\n  &:after {\r\n    border-top-color: #666;\r\n    margin-top: 1px;\r\n    opacity: 0.5;\r\n  }\r\n  &.accending {\r\n    &:after {\r\n      opacity: 1;\r\n    }\r\n    &:before {\r\n      opacity: 0.5;\r\n    }\r\n  }\r\n}\r\n","import { Component, Prop, h, State, Watch, Listen } from '@stencil/core';\r\n\r\nexport interface tableInterface {\r\n  id?: number;\r\n  name?: string;\r\n  username?: string;\r\n  email?: any;\r\n  tabledata?: any;\r\n}\r\n@Component({\r\n  tag: 'ptg-table',\r\n  styleUrl: 'ptg-table.scss',\r\n  shadow: true,\r\n})\r\nexport class PtgTable implements tableInterface {\r\n  page: number = 0;\r\n\r\n  @State() items: any[];\r\n  @State() itemCount = 0;\r\n  @State() pageSize: number = 10;\r\n  @Prop() pageSizeOptions: number[] = [];\r\n\r\n  @Prop() tabledata: any;\r\n  @Prop() sortable: boolean = false;\r\n  @Prop() tablecolumn: any;\r\n  @Prop() customClass?: string;\r\n  @Prop() tableHover?: boolean;\r\n  @Prop() tableStrip?: boolean;\r\n  @Prop() tabletitle: string;\r\n  @Prop() themeColor?: string;\r\n  @Prop() searchable: boolean = false;\r\n  @State() tablelist: any;\r\n  @State() activeSortColumn: string;\r\n\r\n  @State() isSort: boolean = false;\r\n  @State() searchvalue: string = '';\r\n\r\n  tablesort(value: string) {\r\n    if (this.sortable) {\r\n      if (this.isSort) {\r\n        return (this.tablelist = this.tabledata.sort((a, b) => {\r\n          if (a[value] < b[value]) return -1;\r\n          if (a[value] > b[value]) return 1;\r\n          return 0;\r\n        }));\r\n      } else {\r\n        return (this.tablelist = this.tabledata.sort((a, b) => {\r\n          if (a[value] < b[value]) return 1;\r\n          if (a[value] > b[value]) return -1;\r\n          return 0;\r\n        }));\r\n      }\r\n    }\r\n  }\r\n\r\n  @Listen('pageChanged')\r\n  handleSelected(event: CustomEvent) {\r\n    this.page = event.detail;\r\n    const start = this.page * this.pageSize;\r\n    const end = this.page * this.pageSize + this.pageSize;\r\n    this.tablelist = this.tabledata.slice(start, end);\r\n  }\r\n\r\n  @Listen('sizeChanged')\r\n  handleSizeChanged(event: CustomEvent) {\r\n    this.page = 0;\r\n    this.pageSize = event.detail;\r\n    const start = this.page * this.pageSize;\r\n    const end = this.page * this.pageSize + this.pageSize;\r\n    this.tablelist = this.tabledata.slice(start, end);\r\n  }\r\n\r\n  tableOrder(val: string) {\r\n    this.isSort = !this.isSort;\r\n    this.activeSortColumn = val;\r\n    this.tablesort(val.toLowerCase());\r\n  }\r\n  @Watch('searchvalue')\r\n  watchSearch() {\r\n    const start = this.page * this.pageSize;\r\n    const end = this.page * this.pageSize + this.pageSize;\r\n    const keyword = this.searchvalue.toString().toLowerCase();\r\n    if (keyword !== '') {\r\n      const results = this.tabledata.filter((user) => {\r\n        return Object.keys(user).some((key) =>\r\n          user[key].toString().toLowerCase().includes(keyword)\r\n        );\r\n        // Use the toLowerCase() method to make it case-insensitive\r\n      });\r\n      this.tablelist = results.slice(start, end);\r\n    } else {\r\n      this.tablelist = this.tabledata.slice(start, end);\r\n      // If the text field is empty, show all users\r\n    }\r\n  }\r\n  @Watch('tabledata')\r\n  updateTableData() {\r\n    this.tablelist = this.tabledata;\r\n    const start = this.page * this.pageSize;\r\n    const end = this.page * this.pageSize + this.pageSize;\r\n    this.tablelist = this.tabledata.slice(start, end);\r\n  }\r\n  @Listen('valueChanged')\r\n  getinputValue(val: any) {\r\n    this.searchvalue = val.detail;\r\n  }\r\n  componentDidLoad() {\r\n    this.itemCount = this.tabledata.length;\r\n    const start = this.page * this.pageSize;\r\n    const end = this.page * this.pageSize + this.pageSize;\r\n    this.tablelist = this.tabledata.slice(start, end);\r\n  }\r\n\r\n  render() {\r\n    return (\r\n      <div class=\"ptg-table-wrapper\">\r\n        {this.searchable && (\r\n          <div class=\"table-search\">\r\n            <ptg-input placeholder=\"Records..\"></ptg-input>\r\n          </div>\r\n        )}\r\n        <table\r\n          class={{\r\n            'ptg-table': true,\r\n            [`ptg-table-${this.themeColor}`]: !!this.themeColor,\r\n            'ptg-table-strip': !!this.tableStrip,\r\n            'ptg-table-hover': !!this.tableHover,\r\n            [this.customClass]: !!this.customClass,\r\n          }}\r\n        >\r\n          <thead>\r\n            <tr>\r\n              {this.tablecolumn?.map((column) => {\r\n                return (\r\n                  <th\r\n                    class={{\r\n                      sorting: !!this.sortable,\r\n                      accending:\r\n                        this.activeSortColumn === column?.header\r\n                          ? !!this.isSort\r\n                            ? true\r\n                            : false\r\n                          : false,\r\n                    }}\r\n                    onClick={() => {\r\n                      this.tableOrder(column?.header);\r\n                    }}\r\n                  >\r\n                    {column?.header}\r\n                  </th>\r\n                );\r\n              })}\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            {this.tablelist?.length < 1 && (\r\n              <tr>\r\n                <td colSpan={this.tablecolumn.length} class=\"no-record-found\">\r\n                  <strong>No data Found</strong>\r\n                </td>\r\n              </tr>\r\n            )}\r\n            {this.tablelist?.map((tableItem) => {\r\n              return (\r\n                <tr>\r\n                  {this?.tablecolumn.map((column) => {\r\n                    return <td>{tableItem[column?.key]}</td>;\r\n                  })}\r\n                </tr>\r\n              );\r\n            })}\r\n          </tbody>\r\n        </table>\r\n        <ptg-pagination\r\n          page={this.page}\r\n          pageSize={this.pageSize}\r\n          pageSizeOptions={[10, 15, 20]}\r\n          itemCount={this.itemCount}\r\n        ></ptg-pagination>\r\n      </div>\r\n    );\r\n  }\r\n}\r\n"],"mappings":"2CAAA,MAAMA,EAAc,g1E,MCcPC,EAAQ,MALrB,WAAAC,CAAAC,G,UAMEC,KAAIC,KAAW,EAGND,KAASE,UAAG,EACZF,KAAQG,SAAW,GACpBH,KAAeI,gBAAa,GAG5BJ,KAAQK,SAAY,MAOpBL,KAAUM,WAAY,MAIrBN,KAAMO,OAAY,MAClBP,KAAWQ,YAAW,EAmJhC,CAjJC,SAAAC,CAAUC,GACR,GAAIV,KAAKK,SAAU,CACjB,GAAIL,KAAKO,OAAQ,CACf,OAAQP,KAAKW,UAAYX,KAAKY,UAAUC,MAAK,CAACC,EAAGC,KAC/C,GAAID,EAAEJ,GAASK,EAAEL,GAAQ,OAAO,EAChC,GAAII,EAAEJ,GAASK,EAAEL,GAAQ,OAAO,EAChC,OAAO,CAAC,G,KAEL,CACL,OAAQV,KAAKW,UAAYX,KAAKY,UAAUC,MAAK,CAACC,EAAGC,KAC/C,GAAID,EAAEJ,GAASK,EAAEL,GAAQ,OAAO,EAChC,GAAII,EAAEJ,GAASK,EAAEL,GAAQ,OAAO,EAChC,OAAO,CAAC,G,GAOhB,cAAAM,CAAeC,GACbjB,KAAKC,KAAOgB,EAAMC,OAClB,MAAMC,EAAQnB,KAAKC,KAAOD,KAAKG,SAC/B,MAAMiB,EAAMpB,KAAKC,KAAOD,KAAKG,SAAWH,KAAKG,SAC7CH,KAAKW,UAAYX,KAAKY,UAAUS,MAAMF,EAAOC,E,CAI/C,iBAAAE,CAAkBL,GAChBjB,KAAKC,KAAO,EACZD,KAAKG,SAAWc,EAAMC,OACtB,MAAMC,EAAQnB,KAAKC,KAAOD,KAAKG,SAC/B,MAAMiB,EAAMpB,KAAKC,KAAOD,KAAKG,SAAWH,KAAKG,SAC7CH,KAAKW,UAAYX,KAAKY,UAAUS,MAAMF,EAAOC,E,CAG/C,UAAAG,CAAWC,GACTxB,KAAKO,QAAUP,KAAKO,OACpBP,KAAKyB,iBAAmBD,EACxBxB,KAAKS,UAAUe,EAAIE,c,CAGrB,WAAAC,GACE,MAAMR,EAAQnB,KAAKC,KAAOD,KAAKG,SAC/B,MAAMiB,EAAMpB,KAAKC,KAAOD,KAAKG,SAAWH,KAAKG,SAC7C,MAAMyB,EAAU5B,KAAKQ,YAAYqB,WAAWH,cAC5C,GAAIE,IAAY,GAAI,CAClB,MAAME,EAAU9B,KAAKY,UAAUmB,QAAQC,GAC9BC,OAAOC,KAAKF,GAAMG,MAAMC,GAC7BJ,EAAKI,GAAKP,WAAWH,cAAcW,SAAST,OAIhD5B,KAAKW,UAAYmB,EAAQT,MAAMF,EAAOC,E,KACjC,CACLpB,KAAKW,UAAYX,KAAKY,UAAUS,MAAMF,EAAOC,E,EAKjD,eAAAkB,GACEtC,KAAKW,UAAYX,KAAKY,UACtB,MAAMO,EAAQnB,KAAKC,KAAOD,KAAKG,SAC/B,MAAMiB,EAAMpB,KAAKC,KAAOD