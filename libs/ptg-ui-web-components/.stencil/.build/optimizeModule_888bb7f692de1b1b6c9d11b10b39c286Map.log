{"version":3,"names":["ptgSelectCss","PtgSelect","constructor","hostRef","this","multiSelect","expanded","showCheckboxes","render","h","key","id","selected","selectData","map","option","value","caption","class","onClick","htmlFor","type"],"sources":["../../../libs/ptg-ui-web-components/src/components/ptg-select/ptg-select.scss?tag=ptg-select&encapsulation=shadow","../../../libs/ptg-ui-web-components/src/components/ptg-select/ptg-select.tsx"],"sourcesContent":[":host {\r\n  display: block;\r\n}\r\n#optionValue {\r\n  width: 300px;\r\n  border: 1px solid grey;\r\n  height: 30px;\r\n  border-radius: 5px;\r\n}\r\n#multiSelect {\r\n  height: 200px;\r\n  width: 300px;\r\n}\r\n\r\n.multiselect {\r\n  width: 300px;\r\n  ul {\r\n    list-style: none;\r\n    border: 1px solid gray;\r\n    padding: 0px;\r\n    margin-top: 1px;\r\n    border-radius: 4px;\r\n    li {\r\n      padding: 5px 5px 5px 0px;\r\n      & + li {\r\n        border-top: 1px gray solid;\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.selectBox {\r\n  position: relative;\r\n  padding: 7px;\r\n  border: 1px solid gray;\r\n  display: flex;\r\n  align-items: center;\r\n  font-size: 14px;\r\n  border-radius: 4px;\r\n}\r\n\r\n.selectBox select {\r\n  width: 100%;\r\n  width: 300px;\r\n  border: 1px solid grey;\r\n  height: 30px;\r\n  border-radius: 5px;\r\n}\r\n\r\n.overSelect {\r\n  line-height: 1;\r\n}\r\n\r\n#checkboxes {\r\n  display: none;\r\n  border: 1px #dadada solid;\r\n}\r\n\r\n#checkboxes label {\r\n  display: block;\r\n}\r\n\r\n#checkboxes label:hover {\r\n  background-color: #1e90ff;\r\n}\r\n","import { Component, h, Prop, State } from '@stencil/core';\r\n\r\nexport type selectInterface = {\r\n  selectData: { id: number; caption: string }[];\r\n};\r\n\r\n@Component({\r\n  tag: 'ptg-select',\r\n  styleUrl: 'ptg-select.scss',\r\n  shadow: true,\r\n})\r\nexport class PtgSelect implements selectInterface {\r\n  @Prop() selectData: any;\r\n  @Prop() multiSelect: boolean = false;\r\n  @State() expanded: boolean = false;\r\n\r\n  private showCheckboxes = () => {\r\n    this.expanded = !this.expanded;\r\n  };\r\n\r\n  render() {\r\n    return (\r\n      <div>\r\n        {!this.multiSelect && (\r\n          <select id=\"optionValue\">\r\n            <option selected>select</option>\r\n            {this.selectData.map((option) => {\r\n              return <option value={option.caption}>{option.caption}</option>;\r\n            })}\r\n          </select>\r\n        )}\r\n        {this.multiSelect && (\r\n          <div class=\"multiselect\">\r\n            <div class=\"selectBox\" onClick={() => this.showCheckboxes()}>\r\n              <div class=\"overSelect\">Select</div>\r\n            </div>\r\n            {this.expanded && (\r\n              <ul>\r\n                <li>\r\n                  <label htmlFor=\"one\">\r\n                    <input type=\"checkbox\" id=\"one\" />\r\n                    First checkbox\r\n                  </label>\r\n                </li>\r\n                <li>\r\n                  <label htmlFor=\"two\">\r\n                    <input type=\"checkbox\" id=\"two\" />\r\n                    Second checkbox\r\n                  </label>\r\n                </li>\r\n                <li>\r\n                  <label htmlFor=\"three\">\r\n                    <input type=\"checkbox\" id=\"three\" />\r\n                    Third checkbox\r\n                  </label>\r\n                </li>\r\n              </ul>\r\n            )}\r\n          </div>\r\n        )}\r\n      </div>\r\n    );\r\n  }\r\n}\r\n"],"mappings":"2CAAA,MAAMA,EAAe,2tB,MCWRC,EAAS,MALtB,WAAAC,CAAAC,G,UAOUC,KAAWC,YAAY,MACtBD,KAAQE,SAAY,MAErBF,KAAcG,eAAG,KACvBH,KAAKE,UAAYF,KAAKE,QAAQ,CA8CjC,CA3CC,MAAAE,GACE,OACEC,EAAA,OAAAC,IAAA,6CACIN,KAAKC,aACLI,EAAQ,UAAAC,IAAA,2CAAAC,GAAG,eACTF,EAAA,UAAAC,IAAA,2CAAQE,SAAwB,gBAC/BR,KAAKS,WAAWC,KAAKC,GACbN,EAAA,UAAQO,MAAOD,EAAOE,SAAUF,EAAOE,YAInDb,KAAKC,aACJI,EAAK,OAAAC,IAAA,2CAAAQ,MAAM,eACTT,EAAA,OAAAC,IAAA,2CAAKQ,MAAM,YAAYC,QAAS,IAAMf,KAAKG,kBACzCE,EAA