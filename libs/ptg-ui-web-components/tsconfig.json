{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "declaration": false,
    "experimentalDecorators": true,
    "noImplicitOverride": true,
    "lib": ["dom", "es2015"],
    "moduleResolution": "node",
    "module": "esnext",
    "target": "es2017",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react",
    "jsxFactory": "h",
    "types": ["jest"] // Add this line for Jest
    // "types": ["mocha"] // Uncomment this line if you are using Mocha
  },
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}