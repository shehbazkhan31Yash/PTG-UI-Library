{
  "name": "ptg-next-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ptg-next-app",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project ptg-next-app --web",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ptg-next-app",
        "root": "apps/ptg-next-app",
        "fileReplacements": [],
        "assets": []
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "options": {
        "buildTarget": "ptg-next-app:build",
        "dev": true
      },
      "configurations": {
        "production": {
          "dev": false,
          "buildTarget": "ptg-next-app:build:production"
        }
      }
    }
  }
}
